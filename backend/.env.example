APP_NAME=MediaSync115
APP_VERSION=1.2.4
DEBUG=true

# 代理配置 (可选)
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=http://127.0.0.1:7890
# SOCKS_PROXY=socks5://127.0.0.1:7890

NULLBR_APP_ID=your_nullbr_app_id
NULLBR_API_KEY=your_nullbr_api_key
NULLBR_BASE_URL=https://api.nullbr.eu.org/

TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w500
TMDB_LANGUAGE=zh-CN
TMDB_REGION=CN
# 可选：NextFind 风格本地 TMDB SQLite 库。Docker 默认可放在 ./data/tmdb_base.db
TMDB_LOCAL_DB_PATH=data/tmdb_base.db

PAN115_COOKIE=your_115_cookie_here
PANSOU_BASE_URL=http://127.0.0.1:8088/

# HDHive 配置
HDHIVE_COOKIE=your_hdhive_cookie_here
HDHIVE_BASE_URL=https://hdhive.com/

# Telegram 配置
TG_API_ID=your_telegram_api_id
TG_API_HASH=your_telegram_api_hash
TG_PHONE=your_phone_number
TG_CHANNEL_USERNAMES=
TG_SEARCH_DAYS=30
TG_MAX_MESSAGES_PER_CHANNEL=200

# 正式运行使用 PostgreSQL。Docker Compose 默认会创建 postgres 服务并注入同名地址。
DATABASE_URL=postgresql+asyncpg://mediasync:mediasync@postgres:5432/mediasync115

EMBY_URL=http://127.0.0.1:8096/
EMBY_API_KEY=your_emby_api_key
